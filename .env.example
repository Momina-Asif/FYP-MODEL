# Environment Configuration Example
# Copy this file to .env and modify as needed

# Device configuration
DEVICE=cuda  # or 'cpu' for CPU-only mode

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Model paths
LAYOUT_MODEL_PATH=layout_model.pth
TEXT_MODEL_PATH=text_model.pth

# Image generation
IMAGE_SIZE=1024
NUM_BOXES=10
NUM_CLASSES=5

# Stable Diffusion
SD_MODEL_ID=runwayml/stable-diffusion-v1-5
SD_DEVICE=cuda

# Generation parameters
SD_NUM_INFERENCE_STEPS=50
SD_GUIDANCE_SCALE=7.5

# Output
OUTPUT_DIR=output

# Logging
LOG_LEVEL=INFO

# Debug mode
DEBUG=false
